\par }{\rtlch\fcs1 \af0 \ltrch\fcs0 \b\insrsid5903709\charrsid2767477 Ray:\tab }{\rtlch\fcs1 \af0 \ltrch\fcs0 \insrsid1197548\charrsid2767477 Yes.
