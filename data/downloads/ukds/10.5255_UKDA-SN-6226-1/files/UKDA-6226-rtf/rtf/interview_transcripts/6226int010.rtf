\par 
\par }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f39\fs22\lang2057\langfe2057\langnp2057\insrsid5975301 Ray:}{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f39\fs22\lang2057\langfe2057\langnp2057\insrsid15155764\charrsid8024348 \tab }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 
