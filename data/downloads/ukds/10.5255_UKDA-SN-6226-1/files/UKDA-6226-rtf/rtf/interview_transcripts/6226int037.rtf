\par Paul:\tab }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f39\fs22\lang2057\langfe2057\langnp2057\insrsid4982948\charrsid4982948 No! }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f39\fs22\lang2057\langfe2057\langnp2057\insrsid4982948\charrsid4982948 
\par 
\par Judith:\tab }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f39\fs22\lang2057\langfe2057\langnp2057\insrsid4982948\charrsid4982948 And her life was ruined. }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 
\b\f39\fs22\lang2057\langfe2057\langnp2057\insrsid4982948\charrsid4982948 
