\par }\pard \ltrpar\s20\qj \fi-1871\li1871\ri0\widctlpar\wrapdefault\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin1871\itap0\pararsid12846783 {\rtlch\fcs1 \af0 \ltrch\fcs0 \b\insrsid12480245\charrsid4223568 Leonore:\tab }{\rtlch\fcs1 \af0 
\ltrch\fcs0 \insrsid12846783\charrsid4223568 No, no. No. Never. Never.
\par }\pard \ltrpar\s20\qj \fi-1871\li1871\ri0\widctlpar\wrapdefault\aspalpha\aspnum\faauto\adjustright\rin0\lin1871\itap0\pararsid12846783 {\rtlch\fcs1 \af0 \ltrch\fcs0 \insrsid12846783\charrsid4223568 
