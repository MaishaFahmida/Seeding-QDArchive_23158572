\par }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f39\fs22\lang2057\langfe2057\langnp2057\insrsid2451681\charrsid2451681 Paul:\tab }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f39\fs22\lang2057\langfe2057\langnp2057\insrsid10699196\charrsid10699196 
