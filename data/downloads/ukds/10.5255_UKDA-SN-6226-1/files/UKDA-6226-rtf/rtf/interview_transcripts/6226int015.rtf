\fs24\ul\lang2057\langfe1033\cgrid\langnp2057\langfenp1033 {\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f39\fs22\insrsid11671488\charrsid7427796 End of Tape 4 \endash  Side B
