\par }\pard \ltrpar\qj \fi-1871\li1871\ri0\widctlpar\wrapdefault\aspalpha\aspnum\faauto\adjustright\rin0\lin1871\itap0\pararsid2046902 {\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f39\fs22\insrsid3293087 Ann:}{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 
