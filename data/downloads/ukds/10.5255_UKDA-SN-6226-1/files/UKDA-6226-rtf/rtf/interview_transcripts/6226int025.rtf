\par }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f39\fs22\insrsid3293087 Ann:}{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f39\fs22\insrsid6309058\charrsid2046902 \tab }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f39\fs22\insrsid6309058\charrsid2046902 What\rquote 
