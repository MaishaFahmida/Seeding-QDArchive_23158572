\par }\pard \ltrpar\qj \fi-1871\li1871\ri113\widctlpar\wrapdefault\aspalpha\aspnum\faauto\adjustright\rin113\lin1871\itap0\pararsid216898 {\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f39\fs22\lang2057\langfe2057\langnp2057\insrsid1191190\charrsid1191190 Jack:}{
