\par 
\par }{\rtlch\fcs1 \ab\af0\afs22 \ltrch\fcs0 \b\f39\fs22\lang2057\langfe2057\langnp2057\insrsid1191190\charrsid1191190 Paul:}{\rtlch\fcs1 \ab\af0\afs22 \ltrch\fcs0 \f39\fs22\lang2057\langfe2057\langnp2057\insrsid677667\charrsid677667 \tab You don\rquote 
