\par }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f42\fs22\insrsid2717339\charrsid10757096 PAUL:}{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f42\fs22\insrsid2717339   \tab }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f42\fs22\insrsid12849482\charrsid7821535 I don\rquote 
