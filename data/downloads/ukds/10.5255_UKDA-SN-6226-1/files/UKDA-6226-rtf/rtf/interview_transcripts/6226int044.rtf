\par }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f42\fs22\insrsid2717339\charrsid1182077 W.M.:}{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f42\fs22\insrsid2717339   \tab }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f42\fs22\insrsid12849482\charrsid7821535 No, they weren\rquote 
