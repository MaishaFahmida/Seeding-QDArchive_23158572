\par }{\rtlch\fcs1 \af0 \ltrch\fcs0 \b\insrsid10294858\charrsid10294858 Paul:\tab }{\rtlch\fcs1 \af0 \ltrch\fcs0 \insrsid11733749\charrsid10294858 Yes.
