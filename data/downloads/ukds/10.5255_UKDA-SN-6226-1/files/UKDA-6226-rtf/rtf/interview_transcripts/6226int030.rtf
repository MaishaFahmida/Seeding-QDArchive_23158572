\par }\pard \ltrpar\s22\qj \li1871\ri0\widctlpar\wrapdefault\aspalpha\aspnum\faauto\adjustright\rin0\lin1871\itap0\pararsid12220764 {\rtlch\fcs1 \af0 \ltrch\fcs0 \insrsid11733749\charrsid10294858 
