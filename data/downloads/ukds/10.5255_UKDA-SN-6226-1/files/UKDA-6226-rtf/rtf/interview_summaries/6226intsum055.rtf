\par }\pard \ltrpar\ql \li0\ri0\sa200\widctlpar\wrapdefault\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0\pararsid5709978 {\rtlch\fcs1 \af0 \ltrch\fcs0 \f42\ul\insrsid5709978 
