\par }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f39\fs22\ul\insrsid8534382\charrsid8534382 Methods book}{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f39\fs22\insrsid8534382\charrsid8534382  }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f39\fs22\insrsid8534382\charrsid8534382 : }
{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \i\f39\fs22\insrsid8534382\charrsid8534382 Anthropological Practice: Fieldwork and the Ethnographic Method }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \f39\fs22\insrsid8534382\charrsid8534382 (Berg, in press)}{\rtlch\fcs1 
\af0\afs22 \ltrch\fcs0 \b\f39\fs22\insrsid8534382\charrsid8534382  }{\rtlch\fcs1 \af0\afs22 \ltrch\fcs0 \b\f39\fs22\insrsid8534382 
