\lang2057\langfe1033\langnp2057\insrsid15222920\charrsid7763791 {\*\xmlopen\xmlns2{\factoidname place}}{\*\xmlopen\xmlns2{\factoidname City}}C}{\rtlch\fcs1 \af0 \ltrch\fcs0 \lang2057\langfe1033\langnp2057\insrsid6423686\charrsid7763791 ape Town
