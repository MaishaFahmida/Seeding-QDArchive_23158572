\s20\qj \fi-11\li0\ri0\widctlpar\wrapdefault\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0\pararsid16209235 \rtlch\fcs1 \af0\afs22\alang1025 \ltrch\fcs0 \f38\fs22\lang2057\langfe2057\cgrid\langnp2057\langfenp2057 {\rtlch\fcs1 \af0 \ltrch\fcs0 
\insrsid16209235 Wt 39944. 10M 11/43. W.R.R. & S. Ltd. GP 38. (14).}{\rtlch\fcs1 \af0 \ltrch\fcs0 \insrsid16209235 
