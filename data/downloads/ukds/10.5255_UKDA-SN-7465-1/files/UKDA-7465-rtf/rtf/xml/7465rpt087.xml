				<note xml:id="q-4217e013-1390-e311-a968-000bdb5cc6d5" type="theme" n="6">WEEKLY STATISTICAL REPORT</note>
				<note xml:id="q-4317e013-1390-e311-a968-000bdb5cc6d5" type="reporttext" n="7">Week Ending March 27, 1943.</note>
				<note xml:id="q-4417e013-1390-e311-a968-000bdb5cc6d5" type="subject" n="8">WEEKLY STATISTICAL REPORT FIELD BASE CENSOR</note>
				<note xml:id="q-4517e013-1390-e311-a968-000bdb5cc6d5" type="reporttext" n="9">No. 3 Week Ending March 27, 1943</note>
				<note xml:id="q-4617e013-1390-e311-a968-000bdb5cc6d5" type="contact" n="10">TO: G-1, FOR CIRCULATION WITHIN ALLIED FORCE HEADQUARTERS AID FOR FILING IN A.G.SECTION. CONFIDENTIAL Equals British SECRET</note>
				<note xml:id="q-4717e013-1390-e311-a968-000bdb5cc6d5" type="subheader" n="11">FLOW OF MAIL:</note>
				<note xml:id="q-4817e013-1390-e311-a968-000bdb5cc6d5" type="reporttext" n="12">Taken from A.P.O. for Field Base Censor 54,769</note>
