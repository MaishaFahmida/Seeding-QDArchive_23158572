				<note xml:id="q-4a17e013-1390-e311-a968-000bdb5cc6d5" type="reporttext" n="14">Examined of mail returned to A.P.O. 11%</note>
				<note xml:id="q-4b17e013-1390-e311-a968-000bdb5cc6d5" type="subheader" n="15">EXAMINATION:</note>
