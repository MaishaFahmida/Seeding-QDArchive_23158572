\par }\pard \ltrpar\s20\qj \fi-11\li426\ri0\widctlpar\wrapdefault\aspalpha\aspnum\faauto\adjustright\rin0\lin426\itap0\pararsid13459989 {\rtlch\fcs1 \af0 \ltrch\fcs0 \insrsid13459989 
