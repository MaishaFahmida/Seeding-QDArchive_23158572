\s20\qj \fi-720\li720\ri0\widctlpar\wrapdefault\aspalpha\aspnum\faauto\adjustright\rin0\lin720\itap0\pararsid15871012 \rtlch\fcs1 \af0\afs22\alang1025 \ltrch\fcs0 \f39\fs22\lang2057\langfe2057\cgrid\langnp2057\langfenp2057 {\rtlch\fcs1 \af0 \ltrch\fcs0 
\insrsid15871012 Tel. 34 10 00}{\rtlch\fcs1 \af0 \ltrch\fcs0 \insrsid10968932  }{\rtlch\fcs1 \af0 \ltrch\fcs0 \insrsid15871012 
